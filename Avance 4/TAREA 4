<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ventas Temu</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
        }

        header{
            background: linear-gradient(90deg,#ff6b00,#ff9500);
            color:white;
            padding:40px 20px;
            text-align:center;
        }

        .hero{
            background-color:#fff3e6;
            border-radius:15px;
            box-shadow:0 4px 10px rgba(0,0,0,0.1);
        }

        .card{
            transition: transform 0.3s;
            box-shadow:0 4px 8px rgba(0,0,0,0.1);
        }

        .card:hover{
            transform:translateY(-5px);
        }

        aside{
            background-color:#fff;
            border-left:5px solid #ff6b00;
            box-shadow:0 2px 5px rgba(0,0,0,0.1);
        }

        footer{
            background-color:#212529;
            color:white;
            text-align:center;
            padding:20px;
        }

        .btn-temu{
            background-color:#ff6b00;
            color:white;
        }

        .btn-temu:hover{
            background-color:#e65c00;
            color:white;
        }

        @media (max-width:768px){
            header h1{
                font-size:1.8rem;
            }
        }
    </style>
</head>

<body>

<header>
    <h1>Ventas Temu</h1>
    <p>Productos al precio de la página + $4.75 por libra</p>
</header>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
        <a class="navbar-brand" href="#">Temu Shop</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="menu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
                <li class="nav-item"><a class="nav-link" href="#quienes-somos">Quiénes Somos</a></li>
                <li class="nav-item"><a class="nav-link" href="#productos">Productos</a></li>
                <li class="nav-item"><a class="nav-link" href="#contacto">Contacto</a></li>
            </ul>
        </div>
    </div>
</nav>

<main class="container my-4">

    <!-- INICIO -->
    <section id="inicio" class="hero text-center p-5 m-3">
        <h2>Bienvenidos a Ventas Temu</h2>
        <p class="lead">
            Realiza tus pedidos de manera fácil, segura y confiable.
            Traemos productos de moda, hogar, tecnología, belleza y mucho más.
        </p>

        <a href="#contacto" class="btn btn-temu btn-lg">Realiza tu Pedido</a>
    </section>

    <!-- QUIENES SOMOS -->
    <section id="quienes-somos" class="my-5">
        <h2 class="text-center mb-4">Quiénes Somos</h2>

        <div class="row align-items-center">
            <article class="col-md-6">
                <p>
                    Ventas Temu es un emprendimiento creado para facilitar la compra de productos disponibles en la plataforma Temu.
                </p>
                <p>
                    Nos caracterizamos por la responsabilidad, transparencia y atención personalizada.
                </p>
            </article>

            <div class="col-md-6 text-center">
                <img src="https://roicos.com/wp-content/uploads/2024/09/vender-en-temu.jpg"
                    class="img-fluid rounded shadow"
                    alt="Ventas Temu">
            </div>
        </div>
    </section>

    <!-- PRODUCTOS -->
    <section id="productos" class="my-5">
        <h2 class="text-center mb-4">Productos y Servicios</h2>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="https://imagenes.20minutos.es/files/image_640_auto/uploads/imagenes/2023/03/27/li_temu-la-app-de-ropa-barata.png"
                        class="card-img-top">
                    <div class="card-body">
                        <h5>Moda y Ropa</h5>
                        <p>Ropa para damas, caballeros y niños.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="https://marketing4ecommerce.net/wp-content/uploads/2023/07/temu-3.jpg"
                        class="card-img-top">
                    <div class="card-body">
                        <h5>Accesorios</h5>
                        <p>Calzado, bolsos y relojes.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="https://ldnsso.oss-us-east-1.aliyuncs.com/chilat/prod/2025/09/30/855484e6-2248-4454-9b4a-8e58d2134904.png"
                        class="card-img-top">
                    <div class="card-body">
                        <h5>Tecnología</h5>
                        <p>Gadgets y accesorios electrónicos.</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- VIDEO CORREGIDO -->
    <section class="my-5">
        <h2 class="text-center mb-4">Video Informativo sobre Temu</h2>

        <div class="ratio ratio-16x9">
            <iframe 
                src="https://www.youtube.com/embed/r4goLl1ZYME"
                title="Video sobre Temu"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
            </iframe>
        </div>
    </section>

    <!-- CONTACTO -->
    <section id="contacto" class="my-5">
        <h2 class="text-center mb-4">Contáctanos</h2>

        <div class="row">
            <div class="col-md-6">
                <form>
                    <input class="form-control mb-2" placeholder="Nombre">
                    <input class="form-control mb-2" placeholder="Correo">
                    <input class="form-control mb-2" placeholder="Asunto">
                    <textarea class="form-control mb-2" rows="4" placeholder="Mensaje"></textarea>
                    <button class="btn btn-temu">Enviar</button>
                </form>
            </div>

            <div class="col-md-6">
                <p>📧 stefanycorrea85@gmail.com</p>
                <p>📱 0959738860</p>
                <p>📍 Machala, Ecuador</p>
            </div>
        </div>
    </section>

</main>

<aside class="container p-3 m-3">
    <h3>Información Adicional</h3>
    <p>📦 Pedidos todo el mes</p>
    <p>💰 Precio + $4.75 por libra</p>
</aside>

<footer>
    <p>Elaborado por Stefany Leonor Correa Ávila | 2026</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
